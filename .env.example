# Observability
TELEMTRY_ENABLED=false


# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override models per workflow component (LiteLLM format: provider/model-id)
# LAMPE_MODEL_DESCRIBE=openai/gpt-5-nano-2025-08-07
# LAMPE_MODEL_REVIEW_AGGREGATION=openai/gpt-5-2025-08-07
# LAMPE_MODEL_REVIEW_INTENT=openai/gpt-5.2-codex
# LAMPE_MODEL_REVIEW_VALIDATION=openai/gpt-5.1-codex-mini
# Example: use Anthropic for validation:
# LAMPE_MODEL_REVIEW_VALIDATION=anthropic/claude-3-5-sonnet-20241022

# Lampe CI configuration
## GITHUB
### In github action this variable is automatically set
GITHUB_REPOSITORY=<name of target repository>

### Auth Application (https://docs.github.com/en/apps/creating-github-apps)
LAMPE_GITHUB_APP_ID=<app id shown in the setting of the created app>
LAMPE_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."


### Auth User
LAMPE_GITHUB_TOKEN=<api token to github with valid permissions>


## Bitbucket
### In bitbucket pipeline those variable are automatically set
BITBUCKET_WORKSPACE=<name of target workspace>
BITBUCKET_REPO_SLUG=<name of target repository>

### Auth User or Workspace
LAMPE_BITBUCKET_TOKEN=<api token to bitbucket with valid permissions>

### Auth Bitbucket App
LAMPE_BITBUCKET_APP_KEY=<>
LAMPE_BITBUCKET_APP_SECRET=<>


# Pull Request
PR_NUMBER=
PR_HEAD_SHA=
PR_HEAD_BRANCH=
PR_BASE_SHA=
PR_BASE_BRANCH=
PR_TITLE=

# Langfuse
TELEMETRY_ENABLED=false
# LANGFUSE_PUBLIC_KEY=lf_pk_1234567890 # Uncomment this
# LANGFUSE_SECRET_KEY=lf_sk_1234567890 # Uncomment this
LANGFUSE_HOST=http://localhost:3000

## Optional: if you want to create automatically a org, project, user and api keys
## See the README.md Langfuse section for more details.
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=MyOrg
LANGFUSE_INIT_PROJECT_ID=my-project
LANGFUSE_INIT_PROJECT_NAME=MyProject
LANGFUSE_INIT_PROJECT_RETENTION=30
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_1234567890 # Uncomment this
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_1234567890 # Uncomment this
LANGFUSE_INIT_USER_EMAIL=user@example.com # Uncomment this
LANGFUSE_INIT_USER_NAME=admin # Uncomment this
LANGFUSE_INIT_USER_PASSWORD=admin # Uncomment this

## Optional if you want to be more secure locally default to basic secret
# CLICKHOUSE_PASSWORD=
# LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=
# LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=
# LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=
# REDIS_AUTH=
# MINIO_ROOT_PASSWORD=
# POSTGRES_PASSWORD=
# SALT=
# ENCRYPTION_KEY=

# Masking
MASKING_ENABLED=false
